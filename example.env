# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.
#
# Usage:
#   set -a && source .env && set +a
#   ./scripts/post-onboard.sh

# Required for Telegram bridge
TELEGRAM_BOT_TOKEN=

# Name of your NemoClaw sandbox (set during `nemoclaw onboard`)
SANDBOX_NAME=my-assistant

# Optional: restrict bot to specific Telegram user IDs (recommended)
# Get your ID from @userinfobot on Telegram
# Multiple IDs supported, comma-separated: ALLOWED_CHAT_IDS=111111,222222
ALLOWED_CHAT_IDS=
