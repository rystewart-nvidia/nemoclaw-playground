# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# Required for Telegram bridge
TELEGRAM_BOT_TOKEN=

# Name for your openshell sandbox (used in openshell commands)
SANDBOX_NAME=my-assistant

# Optional: restrict bot to your Telegram chat ID only (recommended)
# Get it from: curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
ALLOWED_CHAT_IDS=

# Ollama model to use (must be pulled locally via `ollama pull <model>`)
OLLAMA_MODEL=qwen3.5:9b
