# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.
#
# Usage:
#   source .env
#   nemoclaw start

# Required for Telegram bridge
TELEGRAM_BOT_TOKEN=

# Name of your NemoClaw sandbox (set during `nemoclaw onboard`)
SANDBOX_NAME=my-assistant

# Optional: restrict bot to your Telegram chat ID only (recommended)
# Get it from: curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
ALLOWED_CHAT_IDS=
