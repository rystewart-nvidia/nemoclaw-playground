# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# Required for Telegram bridge
TELEGRAM_BOT_TOKEN=

# Name for your openshell sandbox (used in openshell commands)
SANDBOX_NAME=my-assistant

# Optional: restrict bot to your Telegram chat ID only (recommended)
# Get it from: curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
ALLOWED_CHAT_IDS=

# Ollama model to use (must be pulled locally via `ollama pull <model>`)
OLLAMA_MODEL=qwen3.5:9b

# Context window size in tokens (default: 131072 / 128k)
# Sets both openclaw's conversation budget and num_ctx passed to Ollama.
# Reduce if you hit GPU memory limits; increase if your model supports more.
OLLAMA_CONTEXT_LENGTH=131072

# Optional: override where workspace backups are stored (default: ~/.openclaw/backups)
BACKUP_BASE=./backups
